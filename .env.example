# Production is browser-only: MSW intercepts app API requests and Dexie
# stores data in the user's browser. Postgres URLs are optional local
# utilities for historical Prisma Route Handler tests/migration scripts.
DATABASE_URL="postgresql://verda:verda_dev@localhost:5432/verda?schema=public&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://verda:verda_dev@localhost:5432/verda?schema=public"

# Compatibility shim only. The app always uses MSW, even if a stale
# deployment env still sets NEXT_PUBLIC_API_MODE="real".
NEXT_PUBLIC_API_MODE="mock"

# Auth.js v5 secret used to sign the JWT session cookie (issue #127).
# Generate per-environment with `openssl rand -base64 32`. Required in
# production; in dev Auth.js auto-generates if unset.
AUTH_SECRET="dev-only-replace-me-with-openssl-rand-base64-32"

# Media storage (issue #136). `local` writes uploads to the Next.js
# filesystem adapter and serves them from /api/storage/local/public/*,
# so docker-compose / offline development works without Supabase
# Storage. Set MEDIA_STORAGE_PROVIDER="supabase" in production and
# provide the Supabase project URL / service-role key for short-lived
# signed upload URLs.
MEDIA_STORAGE_PROVIDER="local"
LOCAL_MEDIA_STORAGE_DIR=".verda-storage"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="media"
