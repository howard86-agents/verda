# Local Postgres provisioned by `docker compose up` (see docker-compose.yml,
# issue #126). The two-URL shape mirrors the Supabase Supavisor transaction
# pooler env so swapping the local instance for the hosted pooler is a
# config-only change.
#
# - DATABASE_URL is the pooled URL the app uses at runtime (Route Handlers,
#   server actions). In Supabase this is the :6543 pooler with
#   `pgbouncer=true`; locally it points at the same Postgres on :5432.
# - DIRECT_URL is the direct, non-pooled URL Prisma uses for
#   `prisma migrate` / `db push`. Required in production; matches
#   DATABASE_URL locally.
DATABASE_URL="postgresql://verda:verda_dev@localhost:5432/verda?schema=public&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://verda:verda_dev@localhost:5432/verda?schema=public"

# Toggle backend cutover for the public reader. When `real`, MSW lets
# migrated routes (currently the stories read path) bypass the mock and
# hit the real Next.js Route Handlers backed by Postgres. Anything else
# (or unset) keeps the legacy MSW-only behaviour.
NEXT_PUBLIC_API_MODE="mock"

# Auth.js v5 secret used to sign the JWT session cookie (issue #127).
# Generate per-environment with `openssl rand -base64 32`. Required in
# production; in dev Auth.js auto-generates if unset.
AUTH_SECRET="dev-only-replace-me-with-openssl-rand-base64-32"
