// Verda backend schema (issue #126).
//
// The walking skeleton models the read path for the public stories
// surface: a typed editorial `Section` taxonomy and the `Article`
// content row. Field names mirror the JSON contract the existing MSW
// handler returns today so React Query callers stay unchanged when
// `NEXT_PUBLIC_API_MODE=real` flips them onto the real Route Handlers.
//
// Later slices add Members, BehaviorLogs, GrowthItems, Comments,
// Reactions, MemberBadges and the CMS authoring tables on top of
// these two models — the schema is intentionally narrow here so the
// tracer-bullet migration has a tight blast radius.
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

/// Editorial section taxonomy — Mindful Living, Nutrition, Movement,
/// Earth & Garden, Recipes (issue #87 lifted from the in-browser
/// Dexie store onto Postgres).
model Section {
  id   String @id
  name String

  @@map("sections")
}

/// A single article — brand longread or reader-contributed item.
///
/// `slug` is the public URL key and is unique. Field names match the
/// JSON shape the public reader and CMS already consume so the MSW →
/// Postgres cutover is invisible to callers. `series` and
/// `contributors` are stored as JSON because they're nested objects /
/// short arrays that don't need their own indexed tables yet.
///
/// The mirrored Dexie compound indexes are unary here — Dexie used
/// `id, slug, kind, cat, tag, status, section, submittedBy` as
/// individual indexes; we materialise the most common filters
/// (`kind+status` for the public listing, `section`, `tag`,
/// `submittedBy`) and keep `slug` unique for the per-article fetch.
model Article {
  id           String    @id @default(cuid())
  slug         String    @unique
  kind         String    @default("brand")
  cat          String    @default("")
  tag          String    @default("")
  title        String
  jp           String    @default("")
  sum          String    @default("")
  img          String    @default("")
  imagePrompt  String    @default("")
  imageSeed    Int       @default(0)
  read         Int       @default(0)
  date         String    @default("")
  author       String    @default("")
  src          String?
  sourceUrl    String?
  license      String?
  submittedBy  String?
  contributors Json?
  series       Json?
  bodyJson     String?
  status       String    @default("draft")
  publishedAt  DateTime?
  scheduledAt  DateTime?
  // Section.id; not modeled as a relation yet so the migration matches
  // the additive Dexie shape (issue #87). Issue #135 (taxonomy admin)
  // promotes this to a relation if needed.
  section      String?

  versions ArticleVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, status])
  @@index([section])
  @@index([tag])
  @@index([submittedBy])
  @@index([status])
  @@map("articles")
}

/// CMS article version snapshot (issue #137). One row per `Save
/// version` action on a draft. The full serialized article body
/// lives on the `snapshot` JSON column so a future restore can
/// reconstruct the row without tracking per-field history. Indexed
/// on `(articleId, timestamp)` for the per-article timeline view.
model ArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  timestamp DateTime @default(now())
  snapshot  Json

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, timestamp])
  @@map("article_versions")
}

/// Identity role exposed as a JWT claim by the Auth.js callbacks
/// (issue #127). `reader` is the default for any user who signs in
/// through the public flow; staff roles map onto the existing CMS
/// permission matrix in `apps/web/app/lib/cms-auth.tsx`.
enum Role {
  reader
  editor
  publisher
  admin
  customer_service
}

/// Auth.js v5 identity row. `id` is intentionally *not* `@default(cuid())`
/// because the seed wires reader users to the existing
/// `m_4421` / `m_5102` / … ids the in-browser Dexie store uses, so
/// the JWT `sub` claim round-trips into legacy reader UI without
/// rewriting every component.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(reader)

  accounts      Account[]
  sessions      Session[]
  memberProfile MemberProfile?
  behaviorLogs  BehaviorLog[]
  pointLedger   PointLedgerEntry[]
  growthItems   GrowthItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// Auth.js v5 OAuth account row. Required by the Prisma adapter even
/// when only the Credentials provider is wired up — the adapter still
/// upserts the account model on linking flows.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Auth.js v5 session row. Unused by the JWT session strategy at
/// runtime but the Prisma adapter still demands the table exists.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// Auth.js v5 verification token row. Drives the email-magic-link
/// flow when SMTP lands in a later slice; included now so the
/// adapter has the schema it expects.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Public-facing reader profile attached to a `User` 1:1 (issue #127).
/// Holds the gamification-related identity bits (`displayName`,
/// `joined`) and reserves a slot for the nutrient/level state later
/// slices (#130 gamification core, #131 reader engagement) populate.
/// Staff users without a reader-side surface skip this row.
model MemberProfile {
  id          String @id @default(cuid())
  userId      String @unique
  displayName String
  joined      String @default("")
  initial     String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("member_profiles")
}

/// Gamification: reward rules (issue #130). Each row defines the
/// points awarded for an action and the deduplication strategy.
model RewardRule {
  id        String  @id
  action    String  @unique
  points    Int
  enabled   Boolean @default(true)
  limitType String  @default("per-article")

  @@map("reward_rules")
}

/// Gamification: growth rules (issue #130). Level thresholds and
/// display names for the growth-item progression.
model GrowthRule {
  level     Int    @id
  name      String
  jp        String @default("")
  threshold Int

  @@map("growth_rules")
}

/// Gamification: growth config (issue #130). Single-row config table
/// holding the growth-item quantity cap.
model GrowthConfig {
  id                String @id @default("default")
  maxItemsPerMember Int    @default(3)

  @@map("growth_config")
}

/// Gamification: behavior log (issue #130). Records every rewarded
/// action. The unique constraint on [userId, action, articleId]
/// enforces per-article idempotency at the DB level.
model BehaviorLog {
  id        Int      @id @default(autoincrement())
  userId    String
  action    String
  articleId String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, articleId])
  @@index([userId])
  @@map("behavior_logs")
}

/// Gamification: point ledger (issue #130). Append-only ledger of
/// point awards with running balance.
model PointLedgerEntry {
  id           Int      @id @default(autoincrement())
  userId       String
  amount       Int
  balanceAfter Int
  reason       String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("point_ledger")
}

/// Gamification: growth item (issue #130). Each member holds up to
/// `growthConfig.maxItemsPerMember` items. The active item receives
/// nutrients; completed items become redeemable.
model GrowthItem {
  id           Int       @id @default(autoincrement())
  userId       String
  nutrients    Int       @default(0)
  level        Int       @default(1)
  sequence     Int       @default(1)
  completedAt  DateTime?
  redeemedAt   DateTime?
  redemptionId String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("growth_items")
}

/// Reader engagement: saved article collection (issue #131).
/// Unique on [userId, articleId] — a user can save an article once.
model Collection {
  id        Int      @id @default(autoincrement())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId])
  @@map("collections")
}

/// Reader engagement: article comment (issue #131).
/// Soft-removal via `removedAt` — removed comments are hidden from
/// readers but visible to CMS moderators.
model Comment {
  id        Int       @id @default(autoincrement())
  userId    String
  articleId String
  body      String
  removedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([articleId, createdAt])
  @@index([userId])
  @@map("comments")
}

/// Reader engagement: article reaction (issue #131).
/// Unique on [userId, articleId, kind] — one reaction per kind per
/// user per article. `kind` is one of grew/learned/loved.
model Reaction {
  id        Int      @id @default(autoincrement())
  userId    String
  articleId String
  kind      String
  createdAt DateTime @default(now())

  @@unique([userId, articleId, kind])
  @@index([articleId])
  @@map("reactions")
}

/// Achievement badges (issue #138). Unique on [userId, badgeId] so
/// a badge is granted exactly once per user.
model MemberBadge {
  id        Int      @id @default(autoincrement())
  userId    String
  badgeId   String
  createdAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("member_badges")
}
